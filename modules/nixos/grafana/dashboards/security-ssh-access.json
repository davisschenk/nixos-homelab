{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SSH login activity, failures, and access patterns from systemd journal via Loki",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "SSH Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "title": "Successful Logins (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Accepted\" [$__range]))",
          "legendFormat": "Accepted",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "title": "Failed Attempts (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Failed\" [$__range]))",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "title": "Invalid User Attempts (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Invalid user\" [$__range]))",
          "legendFormat": "Invalid",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "title": "Disconnections (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Disconnected\" [$__range]))",
          "legendFormat": "Disconnected",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Login Activity Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Accepted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "SSH Logins & Failures Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Accepted\" [$__interval]))",
          "legendFormat": "Accepted",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Failed\" [$__interval]))",
          "legendFormat": "Failed",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"systemd\", unit=\"sshd.service\"} |= \"Invalid user\" [$__interval]))",
          "legendFormat": "Invalid user",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Recent Events",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Successful Logins",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"systemd\", unit=\"sshd.service\"} |= \"Accepted\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Failed & Invalid Attempts",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"systemd\", unit=\"sshd.service\"} |~ \"Failed|Invalid user|Connection closed by invalid\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Full SSH Log",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "id": 30,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "All SSH Events",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"systemd\", unit=\"sshd.service\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
